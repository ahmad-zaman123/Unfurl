# Copy to .env and fill in real values. Never commit .env.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Local dev defaults to SQLite; use a Neon Postgres URL in production.
DATABASE_URL=sqlite:///db.sqlite3

# Comma-separated frontend origins allowed to call the API (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175

# Rate-limit + image cache store. Empty = local memory (dev only).
# In production set a Redis URL (e.g. Upstash): rediss://:<pass>@<host>:<port>
REDIS_URL=

# Secret used to HMAC-sign public card image URLs (defaults to SECRET_KEY).
CARD_SIGNING_SECRET=

# Public origin used when building served image URLs (defaults to the request host).
UNFURL_PUBLIC_BASE_URL=

# Production-only (comma-separated), used by config.settings.prod
CSRF_TRUSTED_ORIGINS=https://*.vercel.app
